{
    "version": 2,
    "builds": [
        {
            "src": "Live-Measurements-Api/api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "Live-Measurements-Api/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}